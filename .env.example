# Telegram Bot Configuration

# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Channel ID where messages will be forwarded
CHANNEL_ID=your_channel_id

# Comma-separated keywords to monitor (e.g., keyword1,keyword2,keyword3)
KEYWORD=keyword1,keyword2

# Comma-separated group IDs to monitor (leave empty to monitor all groups)
GROUP_ID=

# Comma-separated blocked words (messages with these words will be ignored)
BLOCKED_WORDS=
